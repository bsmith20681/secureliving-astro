---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import { getCollection, render } from 'astro:content';
import CompanyCard from '../../components/companies/CompanyCard.astro';
import CompanyRating from '../../components/companies/CompanyRating.astro';
import ProsCons from '../../components/companies/ProsCons.astro';
import Admonition from '../../components/Admonition.astro';
import PromoTag from '../../components/PromoTag.astro';
import FAQ from '../../components/FAQ.astro';
import StarRating from '../../components/StarRating.astro';
import ArticlePromoBox from '../../components/companies/ArticlePromoBox.astro';

export async function getStaticPaths() {
  const articles = await getCollection('articles', ({ data }) => {
    return data.category === 'Home Security Systems';
  });

  return articles.map((article) => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);
---

<ArticleLayout
  title={article.data.title}
  subtitle={article.data.subtitle}
  metaDescription={article.data.metaDescription}
  category={article.data.category}
  categorySlug="home-security-systems"
  author={article.data.author}
  pubDate={article.data.pubDate}
  updatedDate={article.data.updatedDate}
  image={article.data.image}
  company={article.data.company}
>
  <Content components={{ CompanyCard, CompanyRating, ProsCons, Admonition, PromoTag, FAQ, StarRating, ArticlePromoBox }} />
</ArticleLayout>
