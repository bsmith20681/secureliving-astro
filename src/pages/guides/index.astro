---
import ArchiveLayout from '../../layouts/ArchiveLayout.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('articles', ({ data }) => {
  return data.category === 'Guides';
});
---

<ArchiveLayout
  title="Guides"
  category="Guides"
  categorySlug="guides"
  articles={articles}
/>
