---
import PageLayout from '../layouts/PageLayout.astro';

const states = [
  "California", "Colorado", "Connecticut", "Delaware", "Iowa",
  "Maryland", "Minnesota", "Montana", "New Jersey", "Oregon",
  "Tennessee", "Texas", "Utah", "Virginia"
];
---

<PageLayout title="Do Not Sell or Share My Personal Information" description="California and other state residents can opt out of the sale or sharing of their personal information under applicable privacy laws.">
  <div class="container">
    <h1>Do Not Sell or Share My Personal Information</h1>

    <p>If you wish to opt out of the sale or sharing of your personal information, please complete the form below. Please note that Pass Line Media may need to decline certain requests depending on the laws and regulations applicable to your location.</p>

    <h2>State Residents Only</h2>
    <p>This form is intended for residents of the following states: California, Colorado, Connecticut, Delaware, Iowa, Maryland, Minnesota, Montana, New Jersey, Oregon, Tennessee, Texas, Utah, or Virginia.</p>
    <p>If you do not reside in one of the states listed above, please do not submit this form. Submissions from ineligible residents will not be processed.</p>

    <h2>Before You Submit</h2>
    <ul>
      <li>All information provided must be accurate and legally valid.</li>
      <li>Your details will be used for identity verification purposes.</li>
      <li>Incomplete or unverifiable submissions will not be fulfilled.</li>
    </ul>

    <h2>Eligibility & Processing</h2>
    <p>Not all individuals are eligible for all types of data requests. This form will be used to determine your eligibility. To protect your privacy, you will be asked to verify that you are either the individual about whom data was collected, or an authorized agent acting on that person's behalf.</p>
    <p>Requests are typically fulfilled within 45 days of verified submission.</p>
  </div>

  <section class="form-page my-8">
    <div class="container form-container">
      <div id="form-success" style="display:none; background:#d4edda; border:1px solid #c3e6cb; color:#155724; padding:1rem 1.25rem; border-radius:6px; margin-bottom:1.5rem;">
        Your request has been received. We will process it within 45 days of verification.
      </div>

      <form id="do-not-sell-form" name="do-not-sell" method="POST" data-netlify="true" data-netlify-honeypot="bot-field">
        <input type="hidden" name="form-name" value="do-not-sell" />
        <p class="form-honeypot" aria-hidden="true">
          <label>Don't fill this out: <input name="bot-field" /></label>
        </p>

        <div class="form-group">
          <label class="form-label required">Request Type</label>
          <div class="quiz-toggle-group">
            <label class="quiz-toggle">
              <input type="radio" name="request-type" value="Do Not Sell My Information" required />
              <span class="quiz-toggle__btn">Do Not Sell My Information</span>
            </label>
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label class="form-label required" for="first-name">First Name</label>
            <input class="form-input" type="text" id="first-name" name="first-name" placeholder="First name" required />
          </div>
          <div class="form-group">
            <label class="form-label required" for="last-name">Last Name</label>
            <input class="form-input" type="text" id="last-name" name="last-name" placeholder="Last name" required />
          </div>
        </div>

        <div class="form-group">
          <label class="form-label required" for="email">Email</label>
          <input class="form-input" type="email" id="email" name="email" placeholder="you@example.com" required />
        </div>

        <div class="form-row">
          <div class="form-group">
            <label class="form-label required" for="state">State</label>
            <select class="form-select" id="state" name="state" required>
              <option value="" disabled selected>Select your state</option>
              {states.map((state) => (
                <option value={state}>{state}</option>
              ))}
            </select>
          </div>
          <div class="form-group">
            <label class="form-label required" for="zip">Zip Code</label>
            <input class="form-input" type="text" id="zip" name="zip" placeholder="12345" pattern="[0-9]{5}" inputmode="numeric" required />
          </div>
        </div>

        <div class="form-group">
          <label class="form-label required" for="request-details">Request Details</label>
          <textarea class="form-textarea" id="request-details" name="request-details" placeholder="Please describe your request..." required></textarea>
        </div>

        <button class="btn" type="submit">Submit Request</button>
      </form>
    </div>
  </section>
</PageLayout>

<script>
  const form = document.getElementById('do-not-sell-form') as HTMLFormElement;
  const successMsg = document.getElementById('form-success') as HTMLElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(form);
    await fetch('/', { method: 'POST', body: data });
    successMsg.style.display = 'block';
    form.reset();
    successMsg.scrollIntoView({ behavior: 'smooth', block: 'center' });
  });
</script>
