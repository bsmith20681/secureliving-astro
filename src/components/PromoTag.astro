---
interface Props {
  text: string;
}

const { text } = Astro.props;
---

<div class="promo-tag">
  <svg class="promo-tag__icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 256 256">
    <path d="M243.31,136,144,36.69A15.86,15.86,0,0,0,132.69,32H40a8,8,0,0,0-8,8v92.69A15.86,15.86,0,0,0,36.69,144L136,243.31a16,16,0,0,0,22.63,0l84.68-84.68a16,16,0,0,0,0-22.63ZM84,96A12,12,0,1,1,96,84,12,12,0,0,1,84,96Z" />
  </svg>
  <span class="promo-tag__text"><strong>PROMOTION:</strong> {text}</span>
</div>

<style>
  .promo-tag {
    display: flex;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-3);
    background: var(--primary-50);
    border-top: 2px dashed var(--primary-200);
    border-radius: var(--radius-sm);
    font-weight:500;
    width: fit-content;
  }

  .promo-tag__icon {
    flex-shrink: 0;
    color: var(--primary-600);
  }

  .promo-tag__text {
    font-size: var(--text-sm);
    color: var(--primary-700);

  }
</style>
