---
/**
 * @component CompanyCard
 * @description Displays a security company card with logo, star rating,
 *   promo banner, pros list, and action buttons.
 * @example <CompanyCard company="vivint" />
 * @example <CompanyCard company="vivint" rank={1} />
 * @props
 *   company: string — slug matching a companies collection entry (required)
 *   rank?: number — optional rank number to display in the top bar
 */
import { getEntry } from 'astro:content';
import { Image } from 'astro:assets';
import PromoTag from '../PromoTag.astro';
import StarRating from '../StarRating.astro';

interface Props {
  company: string;
  rank?: number;
}

const { company, rank } = Astro.props;
const entry = await getEntry('companies', company);
if (!entry) throw new Error(`Company "${company}" not found in companies collection`);
const { name, phone, phoneUnformatted, website, rating, logo, pros, promo } = entry.data;

const telHref = `tel:${phoneUnformatted || phone.replace(/[^0-9+]/g, '')}`;
---

<a href={website} target="_blank" rel="noopener noreferrer" class="company-card">
  {(promo || rank) && (
    <div class="company-card__topbar">
      {rank && <span class="company-card__rank">#{rank}</span>}
      {promo && <span class="company-card__banner">{promo}</span>}
    </div>
  )}

  <div class="company-card__body">
    <div class="company-card__logo-col">
      <div class="company-card__logo">
        <Image src={logo} alt={`${name} logo`} />
      </div>
      <div class="company-card__rating">
        <StarRating rating={rating.overall} id={`card-${company}`} />
      </div>
    </div>

    <div class="company-card__info">
      <div class="mb-3">
       {promo && <PromoTag text={promo} />}
      </div>
      <ul class="company-card__features">
        {pros.slice(0, 3).map((pro) => (
          <li>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
              <polyline points="22 4 12 14.01 9 11.01"/>
            </svg>
            <span>{pro}</span>
          </li>
        ))}
      </ul>
    </div>

    <div class="company-card__actions">
      <span class="company-card__visit-btn">
        See Packages
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="5" y1="12" x2="19" y2="12"/>
          <polyline points="12 5 19 12 12 19"/>
        </svg>
      </span>
      <span class="company-card__phone" onclick={`event.preventDefault(); event.stopPropagation(); window.location.href='${telHref}';`}>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
        {phone}
      </span>
    </div>
  </div>
</a>
