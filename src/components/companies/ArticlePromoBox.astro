---
import { Image } from 'astro:assets';

interface Props {
  company: {
    name: string;
    slug: string;
    logo: ImageMetadata;
    rating: { overall: number };
    website: string;
    promo?: string;
    pros: string[];
    category?: string;
    phone: string,
    phoneUnformatted: string,
  };
}

const { company } = Astro.props;
const { name, logo, rating, website, promo, pros, phone, phoneUnformatted } = company;
const telHref = `tel:${phoneUnformatted}`;

const fullStars = Math.floor(rating.overall);
const hasHalf = rating.overall % 1 >= 0.5;
const emptyStars = 5 - fullStars - (hasHalf ? 1 : 0);
const slug = company.slug;
---

<div class="promo-box">
  <div class="promo-box__logo">
    <Image src={logo} alt={`${name} logo`} width={160} />
  </div>

  <div class="promo-box__rating">
    <div class="promo-box__stars">
      {Array(fullStars).fill(null).map(() => (
        <svg width="18" height="18" viewBox="0 0 24 24" fill="#f59e0b" class="star">
          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
        </svg>
      ))}
      {hasHalf && (
        <svg width="18" height="18" viewBox="0 0 24 24" class="star">
          <defs>
            <linearGradient id={`promo-half-${slug}`}>
              <stop offset="50%" stop-color="#f59e0b"/>
              <stop offset="50%" stop-color="#d1d5db"/>
            </linearGradient>
          </defs>
          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" fill={`url(#promo-half-${slug})`}/>
        </svg>
      )}
      {Array(emptyStars).fill(null).map(() => (
        <svg width="18" height="18" viewBox="0 0 24 24" fill="#d1d5db" class="star">
          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
        </svg>
      ))}
    </div>
    <span class="promo-box__score">{rating.overall}</span>
  </div>

  <a href={website} target="_blank" rel="noopener noreferrer" class="btn">
    See Packages
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
    </svg>
  </a>
  <p class="promo-box__cta-sub">On {name}'s website</p>
        <span class="company-card__phone" onclick={`event.preventDefault(); event.stopPropagation(); window.location.href='${telHref}';`}>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
        {phone}
      </span>


  <div class="promo-box__details">

 <!-- 
    {promo && (
      <div class="promo-box__promo">
        <span class="promo-box__promo-label">PROMOTION:</span> {promo}
      </div>
    )}
-->
    <ul class="promo-box__pros">
      {pros.slice(0, 3).map((pro) => (
        <li>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
          </svg>
          <span>{pro}</span>
        </li>
      ))}
    </ul>
  </div>
</div>

<style>
  .promo-box {
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-md);
    padding: var(--space-5);
    box-shadow: var(--shadow);
  }

  .promo-box__logo {
    text-align: center;
    margin-bottom: var(--space-2);
  }

  .promo-box__logo img {
    max-width: 160px;
    height: auto;
  }

  .promo-box__rating {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-1);
    margin-bottom: var(--space-4);
  }

  .promo-box__stars {
    display: flex;
    align-items: center;
    gap: 2px;
  }

  .promo-box__score {
    font-weight: 700;
    margin-left: var(--space-1);
  }

  .promo-box__cta-sub {
    text-align: center;
    font-size: var(--text-xs);
    color: var(--gray-500);
    margin: var(--space-1-5) 0 var(--space-4);
  }


  .promo-box__details {
    border-top: 1px solid var(--gray-200);
    padding-top: var(--space-3);
  }



  .promo-box__pros {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .promo-box__pros li {
    display: flex;
    align-items: flex-start;
    gap: var(--space-1-5);
    font-size: var(--text-sm);
    color: var(--gray-700);
    line-height: 1.4;
  }

  .promo-box__pros li svg {
    flex-shrink: 0;
    margin-top: 2px;
  }
</style>
