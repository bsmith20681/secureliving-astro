---
/**
 * @component QuizHeader
 * @description Specialized header for quiz/funnel pages with affiliate banner,
 *   disclaimer modal, logo, and "Talk to a Specialist" call dropdown.
 * @usage Replace the standard Header on quiz and lead-gen pages.
 * @example <QuizHeader />
 * @props None
 */
import '../styles/style.css';
import '../styles/flexboxgrid.css';
import '../styles/spacing-utilities.css';
import { Image } from 'astro:assets';
import { getEntry } from 'astro:content';
import logo from '../assets/secureliving-logo-md-300x54.png';
import adtLogo from '../assets/logos/adt-logo.png';
import vivintLogo from '../assets/logos/vivint-logo.png';

const adt = await getEntry('companies', 'adt');
const vivint = await getEntry('companies', 'vivint');
---

<div class="affiliate-banner">
  <div class="container">
    <p>We might earn a commission based on product recommendations at no extra cost to you. <a href="#" class="affiliate-banner__link" id="affiliate-link">Advertising Disclosure</a></p>
  </div>
</div>

<!-- Affiliate Disclaimer Modal -->
<dialog class="affiliate-modal" id="affiliate-modal">
  <div class="affiliate-modal__content">
    <button class="affiliate-modal__close" aria-label="Close">
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="#363636" viewBox="0 0 256 256">
        <path d="M205.66,194.34a8,8,0,0,1-11.32,11.32L128,139.31,61.66,205.66a8,8,0,0,1-11.32-11.32L116.69,128,50.34,61.66A8,8,0,0,1,61.66,50.34L128,116.69l66.34-66.35a8,8,0,0,1,11.32,11.32L139.31,128Z"></path>
      </svg>
    </button>
    <div class="affiliate-modal__body">
      <h2>Affiliate Disclaimer</h2>
      <p>SecureLiving.com is a free online resource that strives to offer helpful content and comparison features to our visitors. Some of our links are affiliate links, which means that if you click on a link and make a purchase, we may earn a commission at no additional cost to you.</p>
      <p>We accept advertising compensation from companies that appear on the site, which may impact the location, order, and score assigned to products and services presented. Company listings on this site do not imply endorsement. We do not feature all providers on the market.</p>
      <p>We only recommend products and services that we believe provide value to our visitors. However, we are not responsible for the quality, accuracy, or performance of any third-party products or services.</p>
      <p>The information, including pricing, which appears on this site is subject to change at any time. Except as expressly set forth in our Terms of Use, all representations and warranties regarding the information presented on this site are disclaimed.</p>
      <p>Your support through these purchases helps us maintain and grow SecureLiving.com, and we sincerely appreciate it.</p>
    </div>
  </div>
</dialog>

<header class="site-header">
  <div class="container">
    <div class="quiz-header-inner">
      <div class="quiz-header-secure">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="var(--black)" viewBox="0 0 256 256">
          <path d="M208,80H176V56a48,48,0,0,0-96,0V80H48A16,16,0,0,0,32,96V208a16,16,0,0,0,16,16H208a16,16,0,0,0,16-16V96A16,16,0,0,0,208,80Zm-72,78.63V184a8,8,0,0,1-16,0V158.63a24,24,0,1,1,16,0ZM160,80H96V56a32,32,0,0,1,64,0Z"></path>
        </svg>
        <span>Secure Form</span>
      </div>
      <span class="site-logo quiz-header-logo">
        <Image src={logo} alt="Secure Living" />
      </span>
      <div class="call-specialist" id="call-specialist">
        <button class="call-specialist__btn" aria-expanded="false" aria-haspopup="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="#fafafa" viewBox="0 0 256 256">
            <path d="M222.37,158.46l-47.11-21.11-.13-.06a16,16,0,0,0-15.17,1.4,8.12,8.12,0,0,0-.75.56L134.87,160c-15.42-7.49-31.34-23.29-38.83-38.51l20.78-24.71c.2-.25.39-.5.57-.77a16,16,0,0,0,1.32-15.06l0-.12L97.54,33.64a16,16,0,0,0-16.62-9.52A56.26,56.26,0,0,0,32,80c0,79.4,64.6,144,144,144a56.26,56.26,0,0,0,55.88-48.92A16,16,0,0,0,222.37,158.46ZM176,208A128.14,128.14,0,0,1,48,80,40.2,40.2,0,0,1,82.87,40a.61.61,0,0,0,0,.12l21,47L83.2,111.86a6.13,6.13,0,0,0-.57.77,16,16,0,0,0-1,15.7c9.06,18.53,27.73,37.06,46.46,46.11a16,16,0,0,0,15.75-1.14,8.44,8.44,0,0,0,.74-.56L168.89,152l47,21.05h0s.08,0,.11,0A40.21,40.21,0,0,1,176,208Z"></path>
          </svg>
          <span>Talk to a Specialist</span>
        </button>
        <div class="call-specialist__dropdown" role="dialog" aria-label="Call Centers">
          <button class="call-specialist__close" aria-label="Close">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="#363636" viewBox="0 0 256 256">
              <path d="M205.66,194.34a8,8,0,0,1-11.32,11.32L128,139.31,61.66,205.66a8,8,0,0,1-11.32-11.32L116.69,128,50.34,61.66A8,8,0,0,1,61.66,50.34L128,116.69l66.34-66.35a8,8,0,0,1,11.32,11.32L139.31,128Z"></path>
            </svg>
          </button>
          <div class="call-specialist__header">
            <div class="call-specialist__header-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="#363636" viewBox="0 0 256 256">
                <path d="M201.89,54.66A103.43,103.43,0,0,0,128.79,24H128A104,104,0,0,0,24,128v56a24,24,0,0,0,24,24H64a24,24,0,0,0,24-24V144a24,24,0,0,0-24-24H40.36A88.12,88.12,0,0,1,190.54,65.93,87.39,87.39,0,0,1,215.65,120H192a24,24,0,0,0-24,24v40a24,24,0,0,0,24,24h24a24,24,0,0,1-24,24H136a8,8,0,0,0,0,16h56a40,40,0,0,0,40-40V128A103.41,103.41,0,0,0,201.89,54.66ZM64,136a8,8,0,0,1,8,8v40a8,8,0,0,1-8,8H48a8,8,0,0,1-8-8V136Zm128,56a8,8,0,0,1-8-8V144a8,8,0,0,1,8-8h24v56Z"></path>
              </svg>
              <span class="glowing-dot"></span>
            </div>
            <div>
              <h3>Agents Are Currently Available</h3>
              <p>Get all your questions answered by a real person</p>
            </div>
          </div>
          <div class="call-specialist__list">
            <a href={`tel:${adt?.data.phoneUnformatted}`} class="call-specialist__company">
              <div class="call-specialist__logo">
                <Image src={adtLogo} alt="ADT logo" />
              </div>
              <div class="call-specialist__info">
                <strong>ADT</strong>
                <span>6 Monitoring Stations</span>
              </div>
              <div class="btn gap-x-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
                </svg>
                {adt?.data.phone}
              </div>
            </a>
            <a href={`tel:${vivint?.data.phoneUnformatted}`} class="call-specialist__company">
              <div class="call-specialist__logo">
                <Image src={vivintLogo} alt="Vivint logo" />
              </div>
              <div class="call-specialist__info">
                <strong>Vivint</strong>
                <span>Smart Home Security</span>
              </div>
              <div class="btn gap-x-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
                </svg>
                {vivint?.data.phone}
              </div>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</header>
<div class="call-specialist__overlay" id="call-specialist-overlay"></div>

<script>
  // Affiliate modal
  const affiliateLink = document.getElementById('affiliate-link');
  const affiliateModal = document.getElementById('affiliate-modal') as HTMLDialogElement;

  if (affiliateLink && affiliateModal) {
    const closeBtn = affiliateModal.querySelector('.affiliate-modal__close');

    affiliateLink.addEventListener('click', (e) => {
      e.preventDefault();
      affiliateModal.showModal();
    });

    closeBtn?.addEventListener('click', () => affiliateModal.close());

    // Close on backdrop click
    affiliateModal.addEventListener('click', (e) => {
      if (e.target === affiliateModal) affiliateModal.close();
    });
  }

  // Call specialist dropdown
  const specialist = document.getElementById('call-specialist');
  const specialistOverlay = document.getElementById('call-specialist-overlay');

  if (specialist && specialistOverlay) {
    const btn = specialist.querySelector('.call-specialist__btn') as HTMLButtonElement;
    const closeBtn = specialist.querySelector('.call-specialist__close');

    const openDropdown = () => {
      specialist.classList.add('call-specialist--open');
      btn.setAttribute('aria-expanded', 'true');
      specialistOverlay.classList.add('is-visible');
      document.body.style.overflow = 'hidden';
    };

    const closeDropdown = () => {
      specialist.classList.remove('call-specialist--open');
      btn.setAttribute('aria-expanded', 'false');
      specialistOverlay.classList.remove('is-visible');
      document.body.style.overflow = '';
    };

    btn?.addEventListener('click', openDropdown);
    closeBtn?.addEventListener('click', closeDropdown);
    specialistOverlay.addEventListener('click', closeDropdown);
  }
</script>
