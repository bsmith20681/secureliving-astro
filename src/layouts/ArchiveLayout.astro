---
import PageLayout from './PageLayout.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

interface Props {
  title: string;
  category: string;
  categorySlug: string;
  articles: CollectionEntry<'articles'>[];
}

const { title, category, categorySlug, articles } = Astro.props;

const authors = await getCollection('authors');
const authorMap = Object.fromEntries(authors.map((a) => [a.id, a.data.name]));

const sortedArticles = [...articles].sort(
  (a, b) => (b.data.updatedDate || b.data.pubDate).getTime() - (a.data.updatedDate || a.data.pubDate).getTime()
);
---

<PageLayout title={title}>
  <div class="archive-header">
    <div class="container">
      <h1>Category: {category}</h1>
    </div>
  </div>

  <div class="container">
    {sortedArticles.length > 0 ? (
      <div class="posts-grid row">
        {sortedArticles.map((article) => {
          const displayDate = (article.data.updatedDate || article.data.pubDate)
            .toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });

          const excerpt = article.data.excerpt || article.data.subtitle;
          const truncatedExcerpt = excerpt.split(/\s+/).slice(0, 25).join(' ') + '...';

          return (
            <div class="col-xs-12 col-sm-6 col-md-4">
              <a href={`/${categorySlug}/${article.id}`} class="post-card">
                {article.data.image ? (
                  <div class="post-card__image">
                    <img src={article.data.image.src} alt={article.data.title} />
                  </div>
                ) : (
                  <div class="post-card__image post-card__image--placeholder">
                    <span>No Image</span>
                  </div>
                )}

                <div class="post-card__content">
                  <span class="post-card__category">{category}</span>

                  <h2 class="post-card__title">{article.data.title}</h2>

                  <div class="post-card__meta">
                    {article.data.author && (
                      <>
                        <span class="post-card__author">By: {authorMap[article.data.author] || article.data.author}</span>
                        <span class="post-card__separator">|</span>
                      </>
                    )}
                    <span class="post-card__date">Last Updated: {displayDate}</span>
                  </div>

                  <div class="post-card__excerpt">{truncatedExcerpt}</div>
                </div>
              </a>
            </div>
          );
        })}
      </div>
    ) : (
      <p class="no-posts">No posts found.</p>
    )}
  </div>
</PageLayout>
